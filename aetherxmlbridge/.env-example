## Local development environment file example

# Database (optional for local H2)
DATABASE_URL=
DB_USERNAME=
DB_PASSWORD=
DB_DRIVER=
HIBERNATE_DIALECT=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Zoho OAuth (US)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Zoho Creator API
# Find these in the Zoho Creator URL: creatorapp.zoho.com/zoho/{ZOHO_OWNER_NAME}/{ZOHO_APP_LINK_NAME}#Report:{ZOHO_REPORT_LINK_NAME}
# Example: ZOHO_OWNER_NAME=andrew3542 | ZOHO_APP_LINK_NAME=aetherservicemanagementapp | ZOHO_REPORT_LINK_NAME=All_Projects
ZOHO_OWNER_NAME=
ZOHO_APP_LINK_NAME=
ZOHO_REPORT_LINK_NAME=
ZOHO_SCOPE_REPORT_LINK_NAME=Automation_Product_Estimate_Scope_Tool_Report

# force oauth
SPRING_PROFILES_ACTIVE=oauth 

# AI Agent
GEMINI_API_KEY=